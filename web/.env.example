# Console (BFF) configuration. Copy to `.env.local` and fill in.

# ── NextAuth / Auth.js v5 ─────────────────────────────────────────────
AUTH_SECRET=<openssl rand -base64 33>
AUTH_URL=http://localhost:4200

# Which environment this console instance points at (drives the env badge).
NEXT_PUBLIC_CORTEX_ENV=dev

# ── Entra ID multi-tenant app registration (see ../ENTRA.md) ──────────
AUTH_MICROSOFT_ENTRA_ID_ID=<client-id>
AUTH_MICROSOFT_ENTRA_ID_SECRET=<client-secret>
# Multi-tenant: keep /common (accepts users from any Entra tenant).
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0

# ── Platform tenant ───────────────────────────────────────────────────
# Users who sign in from THIS Entra tenant are Platform Admins; everyone else
# is a Tenant Admin scoped to their own tenant.
PLATFORM_TENANT_ID=<platform-tenant-guid>

# ── Control-plane API ─────────────────────────────────────────────────
CORTEX_API_URL=http://localhost:8080
