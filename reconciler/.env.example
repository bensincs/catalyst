# In-tenant reconciler configuration. Copy to `.env` and fill in.
CONTROL_PLANE_URL=http://localhost:8080

# Auth: the reconciler requests an Azure token (DefaultAzureCredential) for this
# Cortex API scope. In Azure it's the managed identity (selected by
# AZURE_CLIENT_ID); locally it's your `az login` / a service principal. The
# control plane validates the token via Entra JWKS and maps its tid to a tenant.
CORTEX_API_SCOPE=api://<client-id>/.default
# AZURE_CLIENT_ID=<user-assigned managed identity client id, in Azure>

# Dev only: restrict DefaultAzureCredential to developer credentials (Azure CLI),
# so it skips the ~20s managed-identity probe that isn't reachable off-Azure.
# Unset this (or set to "prod") when running in Azure.
AZURE_TOKEN_CREDENTIALS=dev

# With real Azure credentials the bound tenant is the token's tid, i.e. the
# tenant you're logged into.
TENANT_ID=<tenant-guid>
TENANT_NAME=<org display name>
AZURE_REGION=<region>
AZURE_SUBSCRIPTION_ID=<subscription-id>
PLAN=enterprise

# Reported install identity — set explicitly (no defaults/derivation). In Azure
# these come from the managed-app deployment; locally set them yourself.
FOUNDRY_PROJECT=<project>/agents-prod
RECONCILER_IDENTITY=cortex-recon
RECONCILER_VERSION=0.1.0-dev

POLL_INTERVAL_SECONDS=5
