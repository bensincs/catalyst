# Control-plane API configuration. Copy to `.env` and fill in.
PORT=8080

# Postgres DSN. Local dev example (no password); in Azure this is injected by
# infra/main.bicep as a secret (sslmode=require).
DATABASE_URL=postgres://<user>@localhost:5432/cortex?sslmode=disable

# Entra app registration client id — same value as the console's
# AUTH_MICROSOFT_ENTRA_ID_ID. The API validates each incoming Entra ACCESS token:
# signed by Entra (JWKS), audience == this app, issuer == the token's own tenant,
# carrying the access_as_user scope. See ../../ENTRA.md.
ENTRA_CLIENT_ID=<client-id>

# Defaults below are Entra multi-tenant; only override for sovereign/gov clouds.
# ENTRA_JWKS_URL=https://login.microsoftonline.com/common/discovery/v2.0/keys
# ENTRA_ISSUER_HOST=https://login.microsoftonline.com/
# ENTRA_REQUIRED_SCOPE=access_as_user
# ENTRA_API_AUDIENCE=

# Users whose Entra tenant id equals this are Platform Admins.
PLATFORM_TENANT_ID=<platform-tenant-guid>

CORS_ORIGIN=http://localhost:4200
